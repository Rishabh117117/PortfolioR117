# Copy to .env.local and fill in. NEVER commit real keys.

OPENROUTER_API_KEY=         # powers the live demo assistants via OpenRouter (server-side only, via app/api/ask)
OPENROUTER_MODEL=           # optional — prepends a primary onto the free-first fallback chain
                            # (default chain: gpt-oss-120b:free -> llama-3.3-70b:free -> gemini-2.5-flash-lite @ $0.10/$0.40 MTok)
ANTHROPIC_API_KEY=          # fallback LLM provider — direct Anthropic API (server-side only)
SITE_URL=                   # optional — public site origin, sent as OpenRouter attribution referer
ELECTRICITY_MAPS_API_KEY=   # optional — real grid carbon data for Greener Hours
